{{define "content"}}
    <div class="auth-shell">
        <header class="mb-8 text-center">
            <h1 class="m-0 font-display font-extrabold leading-none uppercase tracking-tight text-[clamp(1.85rem,5.5vw,2.25rem)]">Log in</h1>
            <p class="mt-2 text-text-dim text-[0.95rem]">Welcome back. Sign in to manage your quizzes.</p>
        </header>

        {{if .Message}}
            {{template "authError" .Message}}
        {{end}}

        <form action="/login" method="POST" class="bg-surface border border-border-soft rounded-lg p-6">
            <input type="hidden" name="csrf_token" value="{{csrfToken}}">
            {{if .Next}}<input type="hidden" name="next" value="{{.Next}}">{{end}}

            <div class="form-field">
                <label for="email" class="label-eyebrow">Email</label>
                <input id="email" name="email" type="email" required
                       autocomplete="email"
                       value="{{.Email}}" class="form-input">
            </div>

            <div class="form-field">
                <label for="password" class="label-eyebrow">Password</label>
                <input id="password" name="password" type="password" required
                       autocomplete="current-password"
                       class="form-input">
                <p class="mt-2 text-xs text-text-mute"><a href="/forgot-password" class="underline">Forgot your password?</a></p>
                <p class="mt-2 text-xs text-text-mute"><a href="/verify-email/request" class="underline">Didn't get the verification email?</a></p>
            </div>

            {{/* flex-row-reverse pushes "Log in" to the right (thumb-
                 friendly on phones) while keeping its source position
                 first so keyboard Tab focuses the primary CTA before
                 the secondary register link. justify-between spreads
                 the pair to the row's edges. */}}
            <div class="flex flex-row-reverse flex-wrap items-center justify-between gap-4 pt-2">
                <button type="submit" class="btn-primary">Log in</button>
                {{if .ShowRegister}}
                    <a href="/register" class="text-sm text-text-dim hover:text-text underline-offset-2 hover:underline">No account? Register</a>
                {{end}}
            </div>
        </form>

        {{if .ShowGoogle}}
            {{/* Google sits below the credential form: the password
                 login is the more common path on this deployment, so
                 the form leads and Google is offered as a fallback
                 after the "or" divider. */}}
            <div class="my-6 flex items-center gap-3 text-xs uppercase tracking-[0.18em] text-text-dim" aria-hidden="true">
                <span class="h-px flex-1 bg-border-soft"></span>
                <span>or</span>
                <span class="h-px flex-1 bg-border-soft"></span>
            </div>
            <a href="/login/google{{if .Next}}?next={{.Next | urlquery}}{{end}}" class="flex items-center justify-center gap-3 w-full px-4 py-3 rounded-sm bg-surface border border-border-soft text-text hover:bg-surface-alt no-underline">
                {{template "googleIcon"}}
                <span class="text-sm font-medium">Sign in with Google</span>
            </a>
        {{end}}
    </div>
{{end}}
