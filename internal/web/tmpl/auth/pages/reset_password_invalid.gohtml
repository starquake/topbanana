{{define "content"}}
    <div class="auth-shell text-center">
        <h1 class="m-0 mb-3 font-display font-extrabold leading-none uppercase tracking-tight text-[clamp(1.85rem,5.5vw,2.25rem)]">{{t "resetPasswordInvalid.heading"}}</h1>
        <p class="mt-0 mb-6 text-text-dim text-[0.95rem]">
            {{t "resetPasswordInvalid.body"}}
        </p>

        <a href="/forgot-password" class="btn-primary inline-flex">{{t "resetPasswordInvalid.requestNew"}}</a>
    </div>
{{end}}
