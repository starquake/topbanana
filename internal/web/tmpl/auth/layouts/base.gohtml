<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{envTitleTag}}{{.Title}} - Top Banana!</title>
    {{/* Auth pages share the admin Tailwind stylesheet — one source of truth
         for the dark theme + tokens. Bulma was dropped in #213; the auth
         classes are scanned via the second @source directive in
         tailwind-src.css so they survive tree-shaking. */}}
    <link rel="icon" type="image/svg+xml" href="/static/banana.svg" sizes="any">
    <link rel="manifest" href="/manifest.webmanifest">
    <link rel="apple-touch-icon" href="/static/banana-192.png">
    <meta name="theme-color" content="#ffd23f">
    {{/* Open Graph / Twitter Card metadata. Sitewide defaults — the same
         card shows on every auth page. Per-quiz overrides happen on
         /play/{slugID} in the player SPA, not here. og:image is absolute
         per the OG spec (WhatsApp's parser in particular rejects relative
         paths) — {{ogImage}} resolves to scheme://host/static/og-image.png
         at render time (#294). */}}
    <meta property="og:site_name" content="Top Banana!">
    <meta property="og:title" content="Be the Top Banana!">
    <meta property="og:description" content="Make a quiz, share the link, see who's the top banana.">
    <meta property="og:type" content="website">
    <meta property="og:image" content="{{ogImage}}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="Top Banana! — banana icon and wordmark on a dark background">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Be the Top Banana!">
    <meta name="twitter:description" content="Make a quiz, share the link, see who's the top banana.">
    <meta name="twitter:image" content="{{ogImage}}">
    <link rel="preload" href="/static/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/static/fonts/orbitron-latin.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="stylesheet" href="/static/css/app.css">
    {{/* admin.js is the combined admin/auth/home bundle (#1071). It carries the
         cooldown ticker and the new-password length hint among others; each
         feature self-noops where its anchor is absent, so loading it on every
         auth page is fine. */}}
    <script type="module" src="/static/js/dist/admin.js" defer></script>
    <script>if('serviceWorker' in navigator)navigator.serviceWorker.register('/sw.js');</script>
</head>
<body class="bg-bg text-text font-sans antialiased min-h-dvh leading-relaxed flex flex-col">
{{/* The auth card stays vertically centered in the content region. The
     client surface (#893) drops the shared topbar - the brand wordmark
     and account cross-links live in client_footer instead. */}}
<section class="max-w-shell w-full mx-auto px-5 py-10 flex-1 flex flex-col justify-center">
    {{template "content" .}}
</section>
{{template "client_footer" .}}
</body>
</html>
