<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{envTitleTag}}{{.Title}} - Top Banana!</title>
    <link rel="icon" type="image/svg+xml" href="/assets/banana.svg" sizes="any">
    <meta name="theme-color" content="#0a0a0f">
    <link rel="preload" href="/assets/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/assets/fonts/orbitron-latin.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="stylesheet" href="/assets/css/app.css">
</head>
<body class="bg-bg text-text font-sans antialiased min-h-dvh">
    {{/* Minimal host header: the wordmark links back to the dashboard, and a
         persistent "Session live" indicator (#889) appears when the host already
         has a room open so they know they are mid-session while picking, and can
         jump back to it. */}}
    <header class="flex items-center justify-between gap-4 px-6 py-4 border-b border-border-soft">
        <a href="/admin" class="font-display text-lg font-bold uppercase tracking-tight text-text hover:text-accent">Top Banana</a>
        {{if .LiveSession.Active}}
            <a href="/host/{{.LiveSession.JoinCode}}"
               data-testid="session-live-indicator"
               class="inline-flex items-center gap-2 rounded-full border border-accent-line bg-surface px-3 py-1.5 text-sm text-text-dim hover:text-text hover:border-accent transition-colors">
                <span class="w-2 h-2 rounded-full bg-cyan"></span>
                <span>Session live{{if .LiveSession.QuizTitle}} &mdash; <span class="text-text font-medium">{{.LiveSession.QuizTitle}}</span>{{end}}</span>
            </a>
        {{end}}
    </header>
    {{template "content" .}}
</body>
</html>
