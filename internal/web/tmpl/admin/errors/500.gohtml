{{define "content"}}
    <div class="auth-shell text-center">
        <p class="mb-3 font-display text-text-dim text-xs font-semibold uppercase tracking-[0.2em]">Error 500</p>
        <h1 class="m-0 font-display font-extrabold leading-none uppercase tracking-tight text-[clamp(2rem,6vw,2.75rem)]">Something broke</h1>
        <p class="mt-3 mb-8 text-text-dim text-[0.95rem]">An unexpected error stopped this page from loading. Please try again.</p>
        <a href="/admin" class="btn-primary">Back to admin</a>
    </div>
{{end}}
