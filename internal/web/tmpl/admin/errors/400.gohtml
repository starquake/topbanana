{{define "content"}}
    <div class="auth-shell text-center">
        <p class="mb-3 font-display text-text-dim text-xs font-semibold uppercase tracking-[0.2em]">Error 400</p>
        <h1 class="m-0 font-display font-extrabold leading-none uppercase tracking-tight text-[clamp(2rem,6vw,2.75rem)]">Bad request</h1>
        <p class="mt-3 mb-8 text-text-dim text-[0.95rem]">{{if .Message}}{{.Message}}{{else}}The request couldn't be processed. Check the form and try again.{{end}}</p>
        <a href="/admin" class="btn-primary">Back to admin</a>
    </div>
{{end}}
