<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{.Title}} - Admin</title>
    {{/* Tailwind-only baseline. Bulma + Font Awesome removed in #213. The
         player client (/client/) still uses Bulma directly — that surface
         is intentionally out of scope. Icons in admin templates are inline
         SVGs. */}}
    <link rel="stylesheet" href="/client/css/tokens.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Orbitron:wght@500;600;700;800;900&display=swap">
    <link rel="stylesheet" href="/client/css/admin.css">
</head>
<body class="bg-bg text-text font-sans antialiased min-h-screen leading-relaxed">
{{template "navbar" .}}
<section class="max-w-shell mx-auto px-5 py-10">
    {{template "content" .}}
</section>
</body>
</html>
