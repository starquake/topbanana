<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{envTitleTag}}{{.Title}} - Admin</title>
    {{/* Tailwind-only baseline. Bulma + Font Awesome removed in #213. The
         player client (/client/) still uses Bulma directly — that surface
         is intentionally out of scope. Icons in admin templates are inline
         SVGs. */}}
    <link rel="icon" type="image/svg+xml" href="/static/banana.svg" sizes="any">
    <link rel="manifest" href="/manifest.webmanifest">
    <link rel="apple-touch-icon" href="/static/banana-192.png">
    <meta name="theme-color" content="#ffd23f">
    {{/* Open Graph / Twitter Card metadata. Admin URLs aren't shared
         externally in normal use, but having a sensible preview when they
         are pasted in chat is cheap. Per-quiz overrides happen on
         /play/{slugID} in the player SPA, not here. */}}
    <meta property="og:site_name" content="Top Banana!">
    <meta property="og:title" content="Be the Top Banana!">
    <meta property="og:description" content="Make a quiz, share the link, see who's the top banana.">
    <meta property="og:type" content="website">
    <meta property="og:image" content="{{ogImage}}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="Top Banana! — banana icon and wordmark on a dark background">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Be the Top Banana!">
    <meta name="twitter:description" content="Make a quiz, share the link, see who's the top banana.">
    <meta name="twitter:image" content="{{ogImage}}">
    <link rel="preload" href="/static/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/static/fonts/orbitron-latin.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="stylesheet" href="/static/css/app.css">
    <script src="/static/js/htmx.min.js" defer></script>
    {{/* password-length.js shows a live "too short" hint under the
         set-password input. Self-noops where there is no
         [data-password-length]. */}}
    <script type="module" src="/static/js/dist/password-length.js" defer></script>
    {{/* copy-prompt.js powers the Copy button on the quiz-import page.
         Self-noops where there is no [data-copy-target]. */}}
    <script type="module" src="/static/js/dist/copy-prompt.js" defer></script>
    <script>if('serviceWorker' in navigator)navigator.serviceWorker.register('/sw.js');</script>
</head>
<body class="bg-bg text-text font-sans antialiased min-h-dvh flex flex-col leading-relaxed">
{{template "topbar" .}}
{{/* Shell wrapper (#1245). A page that wants the full-bleed app layout
     redefines "shell"; render.Parse parses the page after the layouts, so the
     page's definition wins. Declared as a block, not an {{if .FullBleed}}
     field, because each admin page passes its own data struct - a field
     reference would fail to evaluate on every page that lacks it. */}}
{{block "shell" .}}
<section class="max-w-shell w-full mx-auto px-5 py-10 grow">
    {{template "content" .}}
</section>
{{end}}
{{/* Build stamp (#663) lives in the shared metadata footer; log out moved
     into the top bar's account cluster (#844). */}}
{{template "site_footer" .}}
{{template "modal_manager" .}}
</body>
</html>
