<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{.Title}} - Admin</title>
    {{/* Tailwind-only baseline. Bulma + Font Awesome removed in #213. The
         player client (/client/) still uses Bulma directly — that surface
         is intentionally out of scope. Icons in admin templates are inline
         SVGs. */}}
    <link rel="icon" type="image/svg+xml" href="/assets/banana.svg" sizes="any">
    {{/* Open Graph / Twitter Card metadata. Admin URLs aren't shared
         externally in normal use, but having a sensible preview when they
         are pasted in chat is cheap. Per-quiz overrides happen on
         /play/{slugID} in the player SPA, not here. */}}
    <meta property="og:site_name" content="Top Banana!">
    <meta property="og:title" content="Be the Top Banana!">
    <meta property="og:description" content="Make a quiz, share the link, see who's the top banana.">
    <meta property="og:type" content="website">
    <meta property="og:image" content="/assets/og-image.png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="Top Banana! — banana icon and wordmark on a dark background">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Be the Top Banana!">
    <meta name="twitter:description" content="Make a quiz, share the link, see who's the top banana.">
    <meta name="twitter:image" content="/assets/og-image.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Orbitron:wght@500;600;700;800;900&display=swap">
    <link rel="stylesheet" href="/assets/css/app.css">
    <script src="/assets/js/htmx.min.js" defer></script>
</head>
<body class="bg-bg text-text font-sans antialiased min-h-screen leading-relaxed">
{{template "navbar" .}}
<section class="max-w-shell mx-auto px-5 py-10">
    {{template "content" .}}
</section>
<script>
    function openModal(id) { document.getElementById(id).classList.remove('hidden'); }
    function closeModal(id) { document.getElementById(id).classList.add('hidden'); }
</script>
</body>
</html>
