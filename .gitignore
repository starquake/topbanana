# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
build/
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# SQLite db
*.sqlite
*.sqlite-shm
*.sqlite-wal

# Dependency directories (remove the comment below to include it)
# vendor/

# Node deps for the esbuild client-bundle pipeline. package.json +
# package-lock.json are committed; the installed tree is not.
node_modules/

# Go workspace file
go.work
go.work.sum

# env files
.env
.env.*
!.env.example

# Uploaded media (default MEDIA_DIR; see internal/config). Runtime uploads,
# never tracked.
media/

# Editor/IDE
# .idea/
# .vscode/

# Distrobox
distrobox.ini

# Claude Code per-session lock file. Created at session start, deleted
# on exit; cluttering `git status` between runs is the only reason this
# is listed here.
.claude/*.lock
